# GoMuseum 生产环境变量（复制为 .env 并填写）
ENVIRONMENT=production
DEBUG=false

# openssl rand -hex 48 生成
SECRET_KEY=

POSTGRES_USER=gomuseum
POSTGRES_PASSWORD=
POSTGRES_DB=gomuseum

# CORS（移动端不受 CORS 限制，此处配置官网/管理后台域名）
ALLOWED_ORIGINS=https://gomuseum.app

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

OPENAI_DAILY_CALL_LIMIT=2000
