# GoMuseum Editor Configuration

root = true

# 所有文件的默认配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Dart 文件配置
[*.dart]
indent_size = 2
max_line_length = 80

# Python 文件配置
[*.py]
indent_size = 4
max_line_length = 88

# JavaScript/TypeScript 文件配置
[*.{js,ts,jsx,tsx}]
indent_size = 2
max_line_length = 80

# JSON 文件配置
[*.json]
indent_size = 2

# YAML 文件配置
[*.{yml,yaml}]
indent_size = 2

# Markdown 文件配置
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# 配置文件
[*.{toml,ini}]
indent_size = 2